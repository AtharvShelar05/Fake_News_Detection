# FakeShield — Environment Configuration Template
# ================================================
# Copy this file to .env and fill in your values.
#
# Usage:
#   copy .env.example .env       (Windows)
#   cp .env.example .env         (Linux/Mac)

# Google Fact Check Tools API Key (optional)
# Get a free key at: https://console.cloud.google.com/
# Enable: "Fact Check Tools API"
# Without this key, the app uses ML-only predictions (still fully functional).
FACT_CHECK_API_KEY=your_google_api_key_here

# News API Key (optional)
# Get a free key at: https://newsapi.org/
# Required for fetch_news() functionality
NEWS_API_KEY=your_news_api_key_here

# Flask settings (optional overrides)
FLASK_ENV=development
FLASK_DEBUG=False
